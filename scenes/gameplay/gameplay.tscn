[sub_resource type="GDScript" id="GDScript_2p25t"]
script/source = "extends Sprite2D

var t = 0

func _ready() -> void:
	move_sprite(0.)

func _process(delta: float) -> void:
	move_sprite(delta)

func move_sprite(delta: float):
	var size = get_viewport().get_visible_rect().size
	t += delta * 1.5
	position.x = size.x * 0.7 + 100.0 * sin(t)
	position.y = size.y / 2.0 + 70.0 * sin(t*1.5)
"

[sub_resource type="BoxMesh" id="BoxMesh_ifoly"]

[sub_resource type="GDScript" id="GDScript_mgt4u"]
script/source = "extends MeshInstance3D


func _process(delta: float) -> void:
	rotation.x += delta
	rotation.y += delta
"

